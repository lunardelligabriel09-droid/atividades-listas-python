
palavras = ['python', 'lista', 'programação', 'código', 'loop', 'função']
numeros = list(range(1, 21))

quadrados = [x**2 for x in range(1, 11)]
pares = [x for x in numeros if x % 2 == 0]
comprimentos = [len(palavra) for palavra in palavras]
palavras_grandes = [palavra.upper() for palavra in palavras if len(palavra) > 5]
tuplas = [(x, x**2) for x in range(1, 6)]

print(quadrados)
print(pares)
print(comprimentos)
print(palavras_grandes)
print(tuplas)